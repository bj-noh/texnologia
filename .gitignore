.swiftpm/
.build/
dist/
DerivedData/

# TEXnologia generated LaTeX build output
.texnologia-build/
.paperforge-build/

# Common LaTeX artifacts
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.lof
*.log
