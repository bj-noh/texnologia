# Keep regression fixtures even when their extensions look like generated files.
!Tests/Fixtures/**/*.log
!Tests/Fixtures/**/*.out

# Local editor state
*.xcuserstate
*.xcuserdata/

# Not published to GitHub
Tests/
docs/

# Fixture-dependent scripts are kept locally only
scripts/smoke_latex_build.sh
scripts/verify_bib_highlighting.sh
scripts/verify_file_routing.sh
scripts/verify_windows_port_readiness.sh
